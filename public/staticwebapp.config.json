{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/images/*.{png,jpg,jpeg,gif,webp,svg}",
      "/assets/*",
      "/*.{css,js,json,ico}"
    ]
  },
  "routes": [
    {
      "route": "/dashboard*",
      "rewrite": "/index.html"
    },
    {
      "route": "/api/*",
      "allowedRoles": [
        "anonymous"
      ]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
